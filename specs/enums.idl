@ Mouse button states.
@ Bitmask representing mouse button press/release events. [detail]
enum MouseButton [flags,hex]
    const None        : 0 @ No buttons active.
    const LeftDown    : 1 @ Left button pressed.
    const LeftUp      : 2 @ Left button released.
    const RightDown   : 4 @ Right button pressed.
    const RightUp     : 8 @ Right button released.
    const MiddleDown  : 16 @ Middle button pressed.
    const MiddleUp    : 32 @ Middle button released.
    const Button4Down : 64 [cname(4_DOWN)] @ Extra button 4 pressed.
    const Button4Up   : 128 [cname(4_UP)] @ Extra button 4 released.
    const Button5Down : 256 [cname(5_DOWN)] @ Extra button 5 pressed.
    const Button5Up   : 512 [cname(5_UP)] @ Extra button 5 released.

@ Measurement units.
@ Supported dimensional units for layout calculations. [detail]
enum DimensionUnit
    const PX  @ Physical pixels (device-dependent)
    const MM  @ Millimeters (physical size)
    const DIP @ Density-independent pixels (logical size)
    const SP  @ Scale-independent pixels (for text)
    const PT  @ Points (1/72 inch)
    const IN  @ Inches (physical size)

@ Graphics features.
@ Bitmask of supported hardware capabilities. [detail]
@ Features can be requested when creating a renderer object {Renderer.Create}. [see]
enum Feature [flags,hex]
    const None                : 0 @ No special features
    const Bindless            : 1 @ Bindless resource access
    const GeometryShader      : 2 @ Geometry shader support
    const MeshShader          : 4 @ Mesh shader support
    const SamplerFilterMinmax : 8 @ Min/max sampler filtering
    const DrawIndirect        : 16 @ Indirect drawing
    const DrawIndirectCount   : 32 @ Indirect count drawing
    const Storage8Bit         : 64 [cname(8_BIT_STORAGE)] @ 8-bit storage support
    const Storage16Bit        : 128 [cname(16_BIT_STORAGE)] @ 16-bit storage support

@ Texture formats.
@ Pixel formats for textures. [detail]
enum Format
    const R4G4Unorm [tokenizer(4)] @ 8-bit packed unsigned normalized format that has a 4-bit R component in bits 4..7, and a 4-bit G component in bits 0..3.
    const R4G4B4A4Unorm [tokenizer(8)] @ 16-bit packed unsigned normalized format that has a 4-bit R component in bits 12..15, a 4-bit G component in bits 8..11, a 4-bit B component in bits 4..7, and a 4-bit A component in bits 0..3.
    const R5G5B5A1Unorm [tokenizer(8)] @ 16-bit packed unsigned normalized format that has a 5-bit R component in bits 11..15, a 5-bit G component in bits 6..10, a 5-bit B component in bits 1..5, and a 1-bit A component in bit 0.
    const R5G6B5Unorm [tokenizer(6)] @ 16-bit packed unsigned normalized format that has a 5-bit R component in bits 11..15, a 6-bit G component in bits 5..10, and a 5-bit B component in bits 0..4.
    const R8Unorm [tokenizer(2)] @ 8-bit unsigned normalized format that has a single 8-bit R component.
    const R8Snorm [tokenizer(2)] @ 8-bit signed normalized format that has a single 8-bit R component.
    const R8Uint [tokenizer(2)] @ 8-bit unsigned integer format that has a single 8-bit R component.
    const R8Sint [tokenizer(2)] @ 8-bit signed integer format that has a single 8-bit R component.
    const R8Srgb [tokenizer(2)] @ 8-bit unsigned normalized format that has a single 8-bit R component stored with sRGB nonlinear encoding.
    const R8Uscaled [tokenizer(2)] @ 8-bit unsigned scaled integer format that has a single 8-bit R component.
    const R8Sscaled [tokenizer(2)] @ 8-bit signed scaled integer format that has a single 8-bit R component.
    const R8G8Unorm [tokenizer(4)] @ 16-bit unsigned normalized format that has an 8-bit R component in byte 0, and an 8-bit G component in byte 1.
    const R8G8Snorm [tokenizer(4)] @ 16-bit signed normalized format that has an 8-bit R component in byte 0, and an 8-bit G component in byte 1.
    const R8G8Uint [tokenizer(4)] @ 16-bit unsigned integer format that has an 8-bit R component in byte 0, and an 8-bit G component in byte 1.
    const R8G8Sint [tokenizer(4)] @ 16-bit signed integer format that has an 8-bit R component in byte 0, and an 8-bit G component in byte 1.
    const R8G8Srgb [tokenizer(4)] @ 16-bit unsigned normalized format that has an 8-bit R component stored with sRGB nonlinear encoding in byte 0, and an 8-bit G component stored with sRGB nonlinear encoding in byte 1.
    const R8G8Uscaled [tokenizer(4)] @ 16-bit unsigned scaled integer format that has an 8-bit R component in byte 0, and an 8-bit G component in byte 1.
    const R8G8Sscaled [tokenizer(4)] @ 16-bit signed scaled integer format that has an 8-bit R component in byte 0, and an 8-bit G component in byte 1.
    const R8G8B8Unorm [tokenizer(6)] @ 24-bit unsigned normalized format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, and an 8-bit B component in byte 2.
    const R8G8B8Snorm [tokenizer(6)] @ 24-bit signed normalized format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, and an 8-bit B component in byte 2.
    const R8G8B8Uint [tokenizer(6)] @ 24-bit unsigned integer format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, and an 8-bit B component in byte 2.
    const R8G8B8Sint [tokenizer(6)] @ 24-bit signed integer format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, and an 8-bit B component in byte 2.
    const R8G8B8Srgb [tokenizer(6)] @ 24-bit unsigned normalized format that has an 8-bit R component stored with sRGB nonlinear encoding in byte 0, an 8-bit G component stored with sRGB nonlinear encoding in byte 1, and an 8-bit B component stored with sRGB nonlinear encoding in byte 2.
    const R8G8B8Uscaled [tokenizer(6)] @ 24-bit unsigned scaled format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, and an 8-bit B component in byte 2.
    const R8G8B8Sscaled [tokenizer(6)] @ 24-bit signed scaled format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, and an 8-bit B component in byte 2.
    const R8G8B8A8Unorm [tokenizer(8)] @ 32-bit unsigned normalized format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, an 8-bit B component in byte 2, and an 8-bit A component in byte 3.
    const R8G8B8A8Snorm [tokenizer(8)] @ 32-bit signed normalized format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, an 8-bit B component in byte 2, and an 8-bit A component in byte 3.
    const R8G8B8A8Uint [tokenizer(8)] @ 32-bit unsigned integer format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, an 8-bit B component in byte 2, and an 8-bit A component in byte 3.
    const R8G8B8A8Sint [tokenizer(8)] @ 32-bit signed integer format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, an 8-bit B component in byte 2, and an 8-bit A component in byte 3.
    const R8G8B8A8Srgb [tokenizer(8)] @ 32-bit unsigned normalized format that has an 8-bit R component stored with sRGB nonlinear encoding in byte 0, an 8-bit G component stored with sRGB nonlinear encoding in byte 1, an 8-bit B component stored with sRGB nonlinear encoding in byte 2, and an 8-bit A component in byte 3.
    const R8G8B8A8Uscaled [tokenizer(8)] @ 32-bit unsigned scaled format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, an 8-bit B component in byte 2, and an 8-bit A component in byte 3.
    const R8G8B8A8Sscaled [tokenizer(8)] @ 32-bit signed scaled format that has an 8-bit R component in byte 0, an 8-bit G component in byte 1, an 8-bit B component in byte 2, and an 8-bit A component in byte 3.
    const R16Unorm [tokenizer(3)] @ 16-bit unsigned normalized format that has a single 16-bit R component.
    const R16Snorm [tokenizer(3)] @ 16-bit signed normalized format that has a single 16-bit R component.
    const R16Uint [tokenizer(3)] @ 16-bit unsigned integer format that has a single 16-bit R component.
    const R16Sint [tokenizer(3)] @ 16-bit signed integer format that has a single 16-bit R component.
    const R16Sfloat [tokenizer(3)] @ 16-bit signed floating-point format that has a single 16-bit R component.
    const R16Uscaled [tokenizer(3)] @ 16-bit unsigned scaled integer format that has a single 16-bit R component.
    const R16Sscaled [tokenizer(3)] @ 16-bit signed scaled integer format that has a single 16-bit R component.
    const R16G16Unorm [tokenizer(6)] @ 32-bit unsigned normalized format that has a 16-bit R component in bytes 0..1, and a 16-bit G component in bytes 2..3.
