@ Result codes.
@ Status/error codes returned by framework methods. [detail]
enum Result [errorcode]
    const Success [noerror] @ Operation completed successfully.
    const SkipFrame [noerror] @ Should skip rendering the frame if this code returned {Renderer.NewFrame}.
    const ErrorUnknown @ Unknown error occurred.
    const ErrorOutOfMemory @ Memory allocation failed.
    const ErrorNotImplemented @ Functionality not available.
    const ErrorFileOpen @ Failed to open file.
    const ErrorFileAllocate @ Failed to allocate file space.
    const ErrorFileWrite @ File write operation failed.
    const ErrorApplicationCreate @ Application initialization failed.
    const ErrorApplicationAlreadyRunning @ Duplicate application instance.
    const ErrorApplicationNotRunning @ Operation requires running application.
    const ErrorApplicationTerminated @ Application was terminated.
    const ErrorNoDisplay @ No display devices found.
    const ErrorDeviceSelection @ Failed to select graphics device.
    const ErrorDeviceLost @ Graphics device became unavailable.
    const ErrorAlreadyExists @ Resource already exists.
    const ErrorNotFound @ Resource not found.
    const ErrorFromCallback @ Error originated in callback function.
    const ErrorFeatureNotSupported @ Hardware feature unavailable.
    const ErrorFormatNotSupported @ Pixel format not supported.
    const ErrorFidelityFxNotSupported @ FidelityFX not supported.
    const ErrorInvalidArgument @ Invalid parameter passed.
    const ErrorInvalidFrameGraph @ Unable to compile frame graph for given nodes.
    const ErrorInvalidResource @ Cannot bind external resource because it has a different resource type.
    const ErrorInvalidOperation @ Illegal operation attempted.
    const ErrorParseSpirv @ SPIR-V parsing failed.
    const ErrorDetectShaderLanguage @ Shader language detection failed.
    const ErrorCompileShader @ Shader compilation error.
    const ErrorBinding @ Resource binding failed.
    const ErrorDescriptor @ Descriptor set error.
    const ErrorLoadTexture @ Texture loading failed.
    const ErrorChangeDisplayMode @ Display mode change rejected.

@ File seek origins.
@ Reference positions for file seek operations. [detail]
enum FileSeek 
    const Begin   @ Seek from start of file.
    const Current @ Seek from current position.
    const End     @ Seek from end of file.

@ Logging severity levels.
@ Hierarchical message importance classification. [detail]
enum LoggerLevel
    const Verbose @ Detailed diagnostic messages.
    const Debug   @ Debugging information.
    const Info    @ Informational messages.
    const Warning @ Potentially problematic situations.
    const Error   @ Recoverable error conditions.
    const Fatal   @ Critical unrecoverable errors.
    const Off     @ No logging output.

@ Runtime platforms.
@ Supported operating systems and execution environments. [detail]
enum RuntimePlatform
    const Unknown @ Undetermined platform.
    const Android @ Android OS.
    const IOS     @ Apple iOS.
    const Web     @ Web browser environment.
    const Windows @ Microsoft Windows.
    const Linux   @ Linux operating system.
    const MacOS   @ Apple macOS.

@ Application state changes.
@ Lifecycle and visibility states of the application. [detail]
enum ApplicationState
    const Unknown      @ Unknown state.
    const Create       @ Application creation started.
    const Destroy      @ Application destruction started.
    const Initialize   @ Window initialized.
    const Uninitialize @ Window shutting down.
    const GotFocus     @ Window gained focus.
    const LostFocus    @ Window lost focus.
    const Visible      @ Window became visible on screen.
    const Invisible    @ Window became hidden/minimized.
    const Normal       @ Restored to normal window state.
    const Minimize     @ Window minimized.
    const Maximize     @ Window maximized.
    const Fullscreen   @ Entered fullscreen mode.
    const Resize       @ Window resize started.
    const Resized      @ Window resize completed.

@ Window style flags.
@ Configurable window decoration and behavior options. [detail]
enum ApplicationStyle [flags]
    const None        : 0 @ No special styling.
    const Resizable   : 1 @ Allow window resizing.
    const Minimizable : 2 @ Show minimize button and allow minimize.
    const Maximizable : 4 @ Show maximize button and allow maximizable.

@ Input event types.
@ Categories of user input events. [detail]
enum EventType
    const Keyboard @ Key press/release events.
    const Mouse    @ Mouse movement/button events.

@ Key state transitions.
@ Keyboard key action states. [detail]
enum KeyState
    const Pressed  @ Key was pressed down.
    const Released @ Key was released up.

@ Keyboard modifier keys.
@ Bitmask of active modifier keys. [detail]
enum KeyMod [flags,hex]
    const None       : 0    @ No modifiers active.
    const Lshift     : 1    @ Left Shift key.
    const Rshift     : 2    @ Right Shift key.
    const Lctrl      : 4    @ Left Control key.
    const Rctrl      : 8    @ Right Control key.
    const Lalt       : 16   @ Left Alt key.
    const Ralt       : 32   @ Right Alt key.
    const Lmeta      : 64   @ Left Meta/OS key.
    const Rmeta      : 128  @ Right Meta/OS key.
    const NumLock    : 256  @ Num Lock enabled.
    const CapsLock   : 512  @ Caps Lock enabled.
    const ScrollLock : 1024 @ Scroll Lock enabled.
    const Shift      : Lshift, Rshift @ Either Shift key.
    const Ctrl       : Lctrl, Rctrl   @ Either Control key.
    const Alt        : Lalt, Ralt     @ Either Alt key.
    const Meta       : Lmeta, Rmeta   @ Either Meta key.

