    const ASTC12x12Sfloat [tokenizer(4-5)] @ ASTC compressed format where each 128-bit compressed texel block encodes a 12×12 rectangle of signed floating-point RGBA texel data.
    const BC1RgbUnorm [tokenizer(3-3)] @ block-compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGB texel data. This format has no alpha and is considered opaque.
    const BC1RgbSrgb [tokenizer(3-3)] @ block-compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGB texel data with sRGB nonlinear encoding. This format has no alpha and is considered opaque.
    const BC1RgbaUnorm [tokenizer(3-4)] @ block-compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGB texel data, and provides 1 bit of alpha.
    const BC1RgbaSrgb [tokenizer(3-4)] @ block-compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGB texel data with sRGB nonlinear encoding, and provides 1 bit of alpha.
    const BC2Unorm [tokenizer(3)] @ block-compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data with the first 64 bits encoding alpha values followed by 64 bits encoding RGB values.
    const BC2Srgb [tokenizer(3)] @ block-compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data with the first 64 bits encoding alpha values followed by 64 bits encoding RGB values with sRGB nonlinear encoding.
    const BC3Unorm [tokenizer(3)] @ block-compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data with the first 64 bits encoding alpha values followed by 64 bits encoding RGB values.
    const BC3Srgb [tokenizer(3)] @ block-compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data with the first 64 bits encoding alpha values followed by 64 bits encoding RGB values with sRGB nonlinear encoding.
    const BC4Unorm [tokenizer(3)] @ block-compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized red texel data.
    const BC4Snorm [tokenizer(3)] @ block-compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of signed normalized red texel data.
    const BC5Unorm [tokenizer(3)] @ block-compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RG texel data with the first 64 bits encoding red values followed by 64 bits encoding green values.
    const BC5Snorm [tokenizer(3)] @ block-compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of signed normalized RG texel data with the first 64 bits encoding red values followed by 64 bits encoding green values.
    const BC6HUfloat [tokenizer(4)] @ block-compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned floating-point RGB texel data.
    const BC6HSfloat [tokenizer(4)] @ block-compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of signed floating-point RGB texel data.
    const BC7Unorm [tokenizer(3)] @ block-compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data.
    const BC7Srgb [tokenizer(3)] @ block-compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data with sRGB nonlinear encoding applied to the RGB components.
    const ETC2R8G8B8Unorm [tokenizer(4-6)] @ ETC2 compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGB texel data. This format has no alpha and is considered opaque.
    const ETC2R8G8B8Srgb [tokenizer(4-6)] @ ETC2 compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGB texel data with sRGB nonlinear encoding. This format has no alpha and is considered opaque.
    const ETC2R8G8B8A1Unorm [tokenizer(4-8)] @ ETC2 compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGB texel data, and provides 1 bit of alpha.
    const ETC2R8G8B8A1Srgb [tokenizer(4-8)] @ ETC2 compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGB texel data with sRGB nonlinear encoding, and provides 1 bit of alpha.
    const ETC2R8G8B8A8Unorm [tokenizer(4-8)] @ ETC2 compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data with the first 64 bits encoding alpha values followed by 64 bits encoding RGB values.
    const ETC2R8G8B8A8Srgb [tokenizer(4-8)] @ ETC2 compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data with the first 64 bits encoding alpha values followed by 64 bits encoding RGB values with sRGB nonlinear encoding applied.
    const EACR11Unorm [tokenizer(3-3)] @ EAC compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized red texel data.
    const EACR11Snorm [tokenizer(3-3)] @ EAC compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of signed normalized red texel data.
    const EACR11G11Unorm [tokenizer(3-6)] @ EAC compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RG texel data with the first 64 bits encoding red values followed by 64 bits encoding green values.
    const EACR11G11Snorm [tokenizer(3-6)] @ EAC compressed format where each 128-bit compressed texel block encodes a 4×4 rectangle of signed normalized RG texel data with the first 64 bits encoding red values followed by 64 bits encoding green values.
    const PVRTC1v2BppUnorm [tokenizer(6-^1-4)] @ PVRTC compressed format where each 64-bit compressed texel block encodes an 8×4 rectangle of unsigned normalized RGBA texel data.
    const PVRTC1v2BppSrgb [tokenizer(6-^1-4)] @ PVRTC compressed format where each 64-bit compressed texel block encodes an 8×4 rectangle of unsigned normalized RGBA texel data with sRGB nonlinear encoding applied to the RGB components.
    const PVRTC1v4BppUnorm [tokenizer(6-^1-4)] @ PVRTC compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data.
    const PVRTC1v4BppSrgb [tokenizer(6-^1-4)] @ PVRTC compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data with sRGB nonlinear encoding applied to the RGB components.
    const PVRTC2v2BppUnorm [tokenizer(6-^1-4)] @ PVRTC compressed format where each 64-bit compressed texel block encodes an 8×4 rectangle of unsigned normalized RGBA texel data.
    const PVRTC2v2BppSrgb [tokenizer(6-^1-4)] @ PVRTC compressed format where each 64-bit compressed texel block encodes an 8×4 rectangle of unsigned normalized RGBA texel data with sRGB nonlinear encoding applied to the RGB components.
    const PVRTC2v4BppUnorm [tokenizer(6-^1-4)] @ PVRTC compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data.
    const PVRTC2v4BppSrgb [tokenizer(6-^1-4)] @ PVRTC compressed format where each 64-bit compressed texel block encodes a 4×4 rectangle of unsigned normalized RGBA texel data with sRGB nonlinear encoding applied to the RGB components.

@ Polygon rendering modes.
@ Controls how polygons are rasterized. [detail]
enum PolygonMode
    const Fill @ Renders filled polygon (standard solid rendering mode).
    const Line @ Renders polygon edges as lines (wireframe mode).
    const Point @ Renders only polygon vertices as points.

@ Primitive topologies.
@ Defines how vertices are assembled into primitives. [detail]
enum PrimitiveTopology
    const PointList @ Treats each vertex as individual point primitive.
    const LineList @ Connects every 2 vertices as separate line segments.
    const LineStrip @ Connects vertices as continuous line strip.
    const TriangleList @ Groups every 3 vertices as separate triangles.
    const TriangleStrip @ Creates triangle strip from vertex sequence.
    const TriangleFan @ Forms triangle fan from shared first vertex.

@ Face culling modes.
@ Controls which polygon faces are discarded. [detail]
enum CullMode
    const None @ Disables face culling (renders all polygons).
    const Front @ Culls front-facing polygons.
    const Back @ Culls back-facing polygons.
    const FrontAndBack @ Culls all faces.

@ Front face orientation.
@ Defines what constitutes a front-facing polygon. [detail]
enum FrontFace
    const CounterClockwise @ Front face has counter-clockwise winding.
    const Clockwise @ Front face has clockwise winding.

@ Comparison operator for depth, stencil, and sampler operations.
@ Comparison operators compare a *reference* and a *test* value, and return a true or false value depending on the comparison operator chosen. [detail]
enum CompareOp
    const Never @ Comparison always evaluates false.
    const Always @ Comparison always evaluates true.
    const Less @ Comparison evaluates whether *reference* is less than *test*.
    const LessOrEqual @ Comparison evaluates whether *reference* is less than or equal to *test*.
    const Greater @ Comparison evaluates whether *reference* is greater than *test*.
    const GreaterOrEqual @ Comparison evaluates whether *reference* is greater than or equal to *test*.
    const Equal @ Comparison evaluates *reference* and *test* for equality.
    const NotEqual @ Comparison evaluates that *reference* is not equal to *test*.

@ Stencil comparison function.
@ ```
    Possible values of the {StencilOpState.FailOp}, {StencilOpState.PassOp} and 
    {StencilOpState.DepthFailOp}, specifying what happens to the stored stencil 
    value if this or certain subsequent tests fail or pass.``` [detail]
@ {StencilOpState} [see]
enum StencilOp
    const Keep @ Keeps the current value.
    const Zero @ Sets the value to 0.
    const Replace @ Sets the value to *reference*.
    const Invert @ Bitwise-inverts the current value.
    const IncrementAndClamp @ Increments the current value and clamps to the maximum representable unsigned value.
    const DecrementAndClamp @ Decrements the current value and clamps to 0.
    const IncrementAndWrap @ Increments the current value and wraps to 0 when the maximum value would have been exceeded.
    const DecrementAndWrap @ Decrements the current value and wraps to the maximum possible value when the value would go below 0.

@ Logical operations.
@ Pixel-wise logical operations between source and destination. [detail]
@ Logical operations are controlled by the {ColorBlendState.LogicOpEnable} and {ColorBlendState.LogicOp}. [note]
@ {ColorBlendState} [see]
enum LogicOp
    const Clear @ Clears destination to 0 (`0`).
    const Set @ Sets destination to 1 (`1`).
    const NoOp @ Leaves destination unchanged (`dst`).
    const Copy @ Copies source to destination (`src`).
    const CopyInverted @ Copies inverted source to destination (`~src`).
    const And @ Performs bitwise AND (`src & dst`).
    const AndReverse @ Performs bitwise AND with inverted dst (`src & ~dst`).
    const AndInverted @ Performs bitwise AND with inverted src (`~src & dst`).
    const Nand @ Performs bitwise NAND (`~(src & dst)`).
    const Or @ Performs bitwise OR (`src | dst`).
    const OrReverse @ Performs bitwise OR with inverted dst (`src | ~dst`).
    const OrInverted @ Performs bitwise OR with inverted src (`~src | dst`).
    const Nor @ Performs bitwise NOR (`~(src | dst)`).
    const Xor @ Performs bitwise XOR (`src ^ dst`).
    const Equivalent @ Performs bitwise equality (`~(src ^ dst)`).
    const Invert @ Inverts destination (`~dst`).

@ Blending operations.
@ ```
    Once the source and destination blend factors have been selected, they along with 
    the source and destination components are passed to the blending operations. RGB 
    and alpha components can use different operations.``` [detail]
enum BlendOp
    const Add @ Adds source and destination (`src + dst`).
    const Subtract @ Subtracts destination from source (`src - dst`).
    const ReverseSubtract @ Subtracts source from destination (`dst - src`).
    const Min @ Takes component-wise minimum (`min(src, dst)`).
    const Max @ Takes component-wise maximum (`max(src, dst)`).

@ Render pass operations.
@ Initial load/store operations for render passes. [detail]
@ {ResourceOutput} [see]
enum RenderPassOp
    const DontCare @ Contents may be discarded.
    const Clear @ Clears attachment to specified value ({ResourceOutput.ClearColorAttachment} or {ResourceOutput.ClearDepthStencilAttachment}).

@ Blending factors.
@ Multiplicative factors for blending operations. [detail]
enum BlendFactor
    const Zero @ Multiplies by `RGB(0,0,0)` and `A(0)`.
    const One @ Multiplies by `RGB(1,1,1)` and `A(1)`.
    const SrcColor @ Multiplies by source color `RGB(src0.rgb)` and `A(src0.a)`.
    const SrcAlpha @ Multiplies by source alpha `RGB(src0.aaa)` and `A(src0.a)`.
    const SrcAlphaSaturate @ Multiplies by `RGB(min(src0.a,1-dst.a))` and `A(1)`.
    const DstColor @ Multiplies by destination color `RGB(dst.rgb)` and `A(dst.a)`.
    const DstAlpha @ Multiplies by destination alpha `RGB(dst.aaa)` and `A(dst.a)`.
    const ConstantColor @ Multiplies by blend constant color `RGB(cnst.rgb)` and `A(cnst.a)`.
    const ConstantAlpha @ Multiplies by blend constant alpha `RGB(cnst.aaa)` and `A(cnst.a)`.
    const Src1Color [tokenizer(4)] @ Multiplies by source1 color `RGB(src1.rgb)` and `A(src1.a)` (dual-source blending).
    const Src1Alpha [tokenizer(4)] @ Multiplies by source1 alpha `RGB(src1.aaa)` and `A(src1.a)` (dual-source blending).
    const OneMinusSrcColor @ Multiplies by `RGB(1-src0.rgb)` and `A(1-src0.a)`.
    const OneMinusSrcAlpha @ Multiplies by `RGB(1-src0.aaa)` and `A(1-src0.a)`.
    const OneMinusDstColor @ Multiplies by `RGB(1-dst.rgb)` and `A(1-dst.a)`.
    const OneMinusDstAlpha @ Multiplies by `RGB(1-dst.aaa)` and `A(1-dst.a)`.
    const OneMinusConstantColor @ Multiplies by `RGB(1-cnst.rgb)` and `A(1-cnst.a)`.
    const OneMinusConstantAlpha @ Multiplies by `RGB(1-cnst.aaa)` and `A(1-cnst.a)`.
    const OneMinusSrc1Color [tokenizer(3-5-4)] @ Multiplies by `RGB(1-src1.rgb)` and `A(1-src1.a)`.
    const OneMinusSrc1Alpha [tokenizer(3-5-4)] @ Multiplies by `RGB(1-src1.aaa)` and `A(1-src1.a)`.

@ Color components.
@ Bitmask controlling which components are written to the framebuffer. [detail]
enum ColorComponent [flags]
    const R : 1 @ Red channel.
    const G : 2 @ Green channel.
    const B : 4 @ Blue channel.
    const A : 8 @ Alpha channel.

@ Buffer usage flags.
@ Bitmask specifying allowed usage of a buffer. [detail]
enum BufferUsage [flags]
    const None     : 0 @ No specific usage.
    const Vertex   : 1 @ The buffer is suitable for passing as an vertex buffer to {CommandBuffer.BindVertexBuffer}.
    const Index    : 2 @ The buffer is suitable for passing as an index buffer to {CommandBuffer.BindIndexBuffer}.
    const Uniform  : 4 @ The buffer is suitable for use as a uniform buffer (UBO).
    const Storage  : 8 @ The buffer is suitable for use as a storage buffer (SSBO).
    const Indirect : 16 @ Used for indirect drawing parameters. The buffer is suitable for passing as the buffer parameter to {CommandBuffer.DrawIndirect}, {CommandBuffer.DrawIndexedIndirect} and {CommandBuffer.DrawMeshTasksIndirect}.

@ Texture dimensionality.
@ Specifies the type of texture. [detail]
enum TextureType
    const Texture1D [cname(1D)] @ 1-dimensional texture.
    const Texture2D [cname(2D)] @ 2-dimensional texture.
    const Texture3D [cname(3D)] @ 3-dimensional texture.
    const Cube @ Cube map texture (6 square faces).

@ Texture filtering modes.
@ Texel sampling methods. [detail]
enum Filter
    const Nearest @ Point sampling (returns nearest texel without interpolation).
    const Linear  @ Bilinear/trilinear interpolation.

@ Texture addressing modes.
@ Behavior when sampling beyond texture coordinates. [detail]
enum AddressMode
    const Repeat @ Tile the texture infinitely (wrap-around).
    const MirroredRepeat @ Tile with mirroring at boundaries.
    const ClampToEdge @ Extend edge texels beyond \[0,1\] range.
    const ClampToBorder @ Use specified border color beyond \[0,1\].
    const MirrorClampToEdge @ Mirror once then clamp to edge.

@ Sampler reduction modes.
@ Special texture filtering operations. [detail]
enum ReductionMode
    const WeightedAverage @ Texel values are combined by computing a weighted average of values in the footprint.
    const Min @ Texel values are combined by taking the component-wise minimum of values in the footprint with non-zero weights.
    const Max @ Texel values are combined by taking the component-wise maximum of values in the footprint with non-zero weights.

@ Specifies how the resource will be used.
@ This enumeration is necessary for setting barriers for the transition of resources between different stages of the pipeline and for the correct construction of the frame graph. [detail]
@ {ResourceInput} [see]
@ {ResourceOutput} [see]
enum ResourceType
    const Buffer @ Specifies that the resource will be used as a buffer.
    const Texture @ Specifies that the resource will be used as a texture.
    const Attachment @ Specifies that the resource will be used as a render target.
    const Reference @ Used as reference input resources, which is necessary in some cases to clarify dependencies for correct graph computation during compilation.

@ Vertex input rates.
@ Frequency of vertex attribute updates. [detail]
enum VertexRate
    const PerVertex @ Fetch new data for each vertex.
    const PerInstance @ Fetch new data for each instance.

@ Index buffer formats.
@ Index data types for indexed rendering. [detail]
enum IndexType
    const UInt16 [tokenizer(0)] @ 16-bit unsigned indices.
    const UInt32 [tokenizer(0)] @ 32-bit unsigned indices.

@ Shader stage types
@ Pipeline programmable stages [detail]
enum ShaderType
    const Vertex @ Vertex processing stage
    const Fragment @ Pixel shading stage
    const Geometry @ Geometry processing stage
    const Compute @ General compute operations
    const Task @ Task shader (mesh shading pipeline)
    const Mesh @ Mesh shader (mesh shading pipeline)

@ Shader languages
@ Supported shading languages [detail]
enum ShaderLanguage
    const Unknown @ Unknown language
    const SpirV [tokenizer(0)] @ Standard Portable Intermediate Representation
    const GLSL @ OpenGL Shading Language
    const HLSL @ High-Level Shading Language
