{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "gerium",
  "version": "1.0.0",
  "builtin-baseline": "d5ec528843d29e3a52d745a64b469f810b2cedbf",
  "dependencies": [
    "mimalloc",
    "cmakerc",
    "rapidhash",
    "ctre",
    "abseil",
    "vulkan-headers",
    "vulkan-memory-allocator",
    "shaderc",
    "fidelityfx",
    "spirv-reflect",
    "marl",
    "stb",
    {
      "name": "imgui",
      "features": [
        {
          "name": "android-binding",
          "platform": "android"
        },
        {
          "name": "win32-binding",
          "platform": "windows"
        },
        {
          "name": "osx-binding",
          "platform": "osx"
        },
        "vulkan-binding"
      ]
    },
    {
      "name": "ktx",
      "features": [
        "vulkan"
      ]
    },

    "yaml-cpp",
    "imguizmo",
    "glm",
    "entt",
    "magic-enum",
    "meshoptimizer",
    "argparse",
    "assimp",
    "gli",
    "stduuid",
    "joltphysics",
    "capnproto",
    {
      "name": "reflectcpp",
      "features": [
        "capnproto"
      ]
    }
  ],
  "overrides": [
    {
      "name": "ctre",
      "version": "3.8.1"
    }
  ]
}
